# AWS Configuration
AWS_REGION=eu-west-1
AWS_ACCESS_KEY_ID=your_access_key_id
AWS_SECRET_ACCESS_KEY=your_secret_access_key

# DynamoDB Tables
DYNAMODB_PRODUCTS_TABLE=dealinstinct-products
DYNAMODB_INVENTORY_TABLE=dealinstinct-inventory
DYNAMODB_ORDERS_TABLE=dealinstinct-orders
DYNAMODB_USERS_TABLE=dealinstinct-users
DYNAMODB_CATEGORIES_TABLE=dealinstinct-categories
DYNAMODB_CART_TABLE=dealinstinct-cart

# Cognito Authentication
COGNITO_USER_POOL_ID=eu-west-1_xxxxxxxx
COGNITO_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx
COGNITO_CLIENT_SECRET=your_client_secret

# S3 Storage
S3_BUCKET_NAME=dealinstinct-media
S3_BUCKET_REGION=eu-west-1

# Stripe Payments
STRIPE_SECRET_KEY=your_stripe_secret_key_here
STRIPE_PUBLISHABLE_KEY=your_stripe_publishable_key_here
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret_here

# Application
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=Dealinstinct

# Feature Flags
ENABLE_ANALYTICS=true
ENABLE_INVENTORY_ALERTS=true
